# Environment Variables for Superbloom Academy Frontend

# Backend API URL for the application
REACT_APP_BACKEND_URL=https://train-superbloom.preview.emergentagent.com

# Webpack Dev Server socket port (443 for HTTPS)
WDS_SOCKET_PORT=443

# Enable or disable health check functionality
ENABLE_HEALTH_CHECK=false

# Formspree Form IDs for form submissions
# Replace with your actual Formspree form IDs from https://formspree.io

#https://formspree.io/f/mbdjlqvl
REACT_APP_FORMSPREE_APPLICATION_ID=mbdjlqvl


#https://formspree.io/f/xregbrwg
REACT_APP_FORMSPREE_CONTACT_ID=xregbrwg
